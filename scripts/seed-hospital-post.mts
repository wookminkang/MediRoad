/**
 * 병원 포스트 샘플 시드 — 리움한방병원(종로)에 게시글 1건.
 * 실행: node --env-file=.env.local --import tsx scripts/seed-hospital-post.mts
 */
import { createClient } from "@supabase/supabase-js";

const sb = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!,
  { auth: { persistSession: false } },
);

// 대상 병원 (slug "리움한방병원" = 종로구)
const { data: h, error: hErr } = await sb
  .from("hospitals")
  .select("id, name, slug")
  .eq("slug", "리움한방병원")
  .maybeSingle();
if (hErr) throw hErr;
if (!h) throw new Error("리움한방병원(slug) 병원을 찾을 수 없습니다.");

