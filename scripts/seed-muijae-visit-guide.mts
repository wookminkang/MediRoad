 * HOSPITAL_POST_GUIDE.md(v2) 사실 기반 골격: 무엇→어디→무슨 진료→이용안내→FAQ.
 * 실행: node --env-file=.env.local --import tsx scripts/seed-muijae-visit-guide.mts
 */
import { createClient } from "@supabase/supabase-js";

const sb = createClient(
  process.env.NEXT_PUBLIC_SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!,
  { auth: { persistSession: false } },
);

async function hid(slug: string) {
  const { data, error } = await sb
    .from("hospitals")
    .select("id, name, slug")
    .eq("slug", slug)
    .maybeSingle();
  if (error) throw error;
  if (!data) throw new Error(`${slug} 병원을 찾을 수 없습니다.`);
  return data;
}

